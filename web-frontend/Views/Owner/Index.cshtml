@model IEnumerable<PawsCare.Web.Models.Owner>
@{
    ViewData["Title"] = "Owners";
}

<div class="container mt-4">
    <h1>Pet Owners</h1>
    <a asp-action="Create" class="btn btn-primary mb-3">Register New Owner</a>
    
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Address</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var owner in Model)
            {
                <tr>
                    <td>@owner.FirstName @owner.LastName</td>
                    <td>@owner.Email</td>
                    <td>@owner.Phone</td>
                    <td>@owner.Address</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@owner.Id" class="btn btn-sm btn-info">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
