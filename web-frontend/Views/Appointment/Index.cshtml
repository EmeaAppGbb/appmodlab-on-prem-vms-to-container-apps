@model IEnumerable<PawsCare.Web.Models.Appointment>
@{
    ViewData["Title"] = "Appointments";
}

<div class="container mt-4">
    <h1>Appointments</h1>
    <a asp-action="Create" class="btn btn-primary mb-3">Book Appointment</a>
    
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Date</th>
                <th>Patient</th>
                <th>Veterinarian</th>
                <th>Type</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null)
            {
                @foreach (var appointment in Model)
                {
                    <tr>
                        <td>@appointment.AppointmentDate.ToString("MMM dd, yyyy HH:mm")</td>
                        <td>@appointment.PatientName</td>
                        <td>@appointment.VetName</td>
                        <td>@appointment.AppointmentType</td>
                        <td>@appointment.Status</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@appointment.Id" class="btn btn-sm btn-info">Details</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
